generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}
model Developer {
  id         Int       @id @default(autoincrement())
  nome       String
  githubUrl  String    @unique
  senha      String
  projetos   Project[]
}
model Project {
  id                    Int        @id @default(autoincrement())
  titulo                String
  descricao             String
  tecnologiaPrincipal   String

  developerId Int
  developer   Developer @relation(fields: [developerId], references: [id])
}